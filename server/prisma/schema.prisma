generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  language     String   @default("fr")
  country      String
  createdAt    DateTime @default(now()) @map("created_at")

  class Class?

  @@map("teachers")
}

model Class {
  id        String   @id @default(uuid())
  name      String
  country   String
  language  String   @default("fr")
  createdAt DateTime @default(now()) @map("created_at")

  teacherId String  @unique @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  sentConnections     ClassConnection[] @relation("Requester")
  receivedConnections ClassConnection[] @relation("Receiver")

  posts    Post[]
  comments Comment[]

  proposedGames HangmanGame[]  @relation("Proposer")
  guesses       HangmanGuess[]

  @@unique([name, country])
  @@map("classes")
}

model ClassConnection {
  id        String           @id @default(uuid())
  status    ConnectionStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  requesterId String @map("class_requester_id")
  receiverId  String @map("class_receiver_id")

  requester Class @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  Class @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  games HangmanGame[]

  @@unique([requesterId, receiverId])
  @@map("class_connections")
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String?
  mediaType MediaType @default(TEXT) @map("media_type")
  mediaUrl  String?   @map("media_url")
  createdAt DateTime  @default(now()) @map("created_at")

  classId String @map("class_id")
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  comments Comment[]

  @@map("posts")
}

enum MediaType {
  TEXT
  IMAGE
  AUDIO
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  classId String @map("class_id")
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model HangmanGame {
  id              String    @id @default(uuid())
  word            String
  hint            String?
  language        String
  state           GameState @default(ACTIVE)
  maxWrongGuesses Int       @default(6) @map("max_wrong_guesses")
  createdAt       DateTime  @default(now()) @map("created_at")
  finishedAt      DateTime? @map("finished_at")

  connectionId String          @map("connection_id")
  connection   ClassConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  proposerClassId String @map("proposer_class_id")
  proposer        Class  @relation("Proposer", fields: [proposerClassId], references: [id])

  winnerClassId String? @map("winner_class_id")

  guesses HangmanGuess[]

  @@map("hangman_games")
}

enum GameState {
  ACTIVE
  FINISHED
}

model HangmanGuess {
  id        String   @id @default(uuid())
  letter    String   @db.Char(1)
  correct   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  gameId String      @map("game_id")
  game   HangmanGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  classId String @map("class_id")
  class   Class  @relation(fields: [classId], references: [id])

  @@unique([gameId, letter])
  @@map("hangman_guesses")
}
